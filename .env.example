# --- application ---
APP_ENV=dev

# --- storage paths (relative to repo root) ---
DB_PATH=./var/aivedio.db
ASSETS_DIR=./assets
RUNS_DIR=./var/runs
CONFIGS_DIR=./configs

# --- LLM providers ---
# Use a relay station / OpenAI-compatible endpoint or the official URL.
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=

# Anthropic (writing / culture review).
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_API_KEY=

# --- model assignment (override task → model mapping) ---
MODEL_RESEARCH=gpt-5.5
MODEL_WRITING=claude-opus-4-7
MODEL_STRUCTURE=gpt-5.5
MODEL_VISION=gpt-image-2
MODEL_LIGHTWEIGHT=gpt-5.4-mini

# --- transport ---
SSE_KEEPALIVE_SECONDS=15
REQUEST_TIMEOUT_SECONDS=120

# --- frontend ---
NEXT_PUBLIC_API_BASE=http://localhost:8000
